[DEFAULT]
core_plugin = ml2
service_plugins = ovn-router
auth_strategy = keystone
state_path = /var/lib/neutron
allow_overlapping_ips = True
# 컨트롤러 IP (172.30.1.146) 사용
transport_url = rabbit://openstack:{{ rabbit_password }}@{{ hostvars['controller']['mgmt_ip'] }}:5672/

[keystone_authtoken]
www_authenticate_uri = http://{{ hostvars['controller']['mgmt_ip'] }}:5000
auth_url = http://{{ hostvars['controller']['mgmt_ip'] }}:5000
memcached_servers = {{ hostvars['controller']['mgmt_ip'] }}:11211
auth_type = password
project_domain_name = Default
user_domain_name = Default
project_name = service
username = neutron
password = {{ NEUTRON_PASS }}

[oslo_concurrency]
lock_path = $state_path/lock