# 공통 기본 설정
driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync
logdir /var/log/chrony

{% if inventory_hostname in groups['controllers'] %}
# [Controller Node 설정]
# 외부 NTP 서버 (기본값)
server pool.ntp.org iburst
# 요청하신 로컬 네트워크 클라이언트 접속 허용
allow {{ network_cidr }}
{% else %}
# [Compute Node 설정]
# 기본 서버 주석 처리하고 컨트롤러 지정
# server 0.centos.pool.ntp.org iburst (자동 삭제됨)
server controller iburst
{% endif %}
